# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Database (Postgres + pgvector) ────────────────────────────────────────────
DATABASE_URL=postgresql://jobagent:jobagent@localhost:5432/jobagent

# ── Cache / rate-limiting ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Messaging ─────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Object store (S3-compatible — resumes, generated variants, screenshots) ───
S3_ENDPOINT=
S3_BUCKET=jobagent
S3_ACCESS_KEY=
S3_SECRET_KEY=

