# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Database (Postgres + pgvector) ────────────────────────────────────────────
DATABASE_URL=postgresql://jobagent:jobagent@localhost:5432/jobagent

# ── Cache / rate-limiting ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Messaging ─────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Object store (S3-compatible — resumes, generated variants, screenshots) ───
S3_ENDPOINT=
S3_BUCKET=jobagent
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── Phase 2: email tracking ───────────────────────────────────────────────────
# Create credentials at console.cloud.google.com → APIs & Services → Credentials
# Scopes needed: https://www.googleapis.com/auth/gmail.readonly
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT_URI=http://localhost:8085/tracker/callback

# 32-byte AES-256 key for encrypting OAuth tokens at rest, base64-encoded.
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# ── Phase 2: ATS APIs (Tier 1 auto-submit) ───────────────────────────────────
# GREENHOUSE_API_KEY=
# LEVER_API_KEY=
